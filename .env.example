# Phoenix Cloud (free tier) — get from https://app.phoenix.arize.com
PHOENIX_API_KEY=px_live_REPLACE_ME
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space
PHOENIX_PROJECT_NAME=crucible

# Gemini — choose ONE auth mode:
# (A) AI Studio (free tier, capped ~20 req/day):
GOOGLE_API_KEY=REPLACE_ME
GEMINI_MODEL=gemini-3-flash-preview  # free-tier OK; gemini-3-pro-preview needs billing
# (B) Vertex AI (uses Google Cloud credits — $300 trial / lab credits; no daily cap):
#   run `gcloud auth application-default login` first, then set:
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Crucible data paths
CRUCIBLE_DB_PATH=data/world_1/world_1.sqlite
CRUCIBLE_SPIDER_DEV=data/spider/dev.json
